on":{"selectedKey":1,"visible":false},"title":{"rType":"text","val":"Identify relevant drought mitigation measures"},"extendedDesc":{"visible":true,"text":{"rType":"text","val":"Relevant measures are identified based on drought vulnerability and impact assessments conducted during earlier stages of drought management plan or policy development. Actions should address the root causes of identified impacts, rather than just the symptoms."}},"desc":{"rType":"text","val":""}},"XHZzY-RlR":{"type":"element","id":"XHZzY-RlR","color":{"opac":1,"rgb":"var(--TC2)"},"icon":{"selectedKey":1,"visible":false},"title":{"rType":"text","val":"Tailor actions to context"},"extendedDesc":{"visible":true,"text":{"rType":"text","val":"Actions are designed to be location-specific and scale-appropriate, addressing the unique challenges of different areas and societal levels (national, regional, local)."}}},"sPYl1Y3hm":{"type":"element","id":"sPYl1Y3hm","color":{"opac":1,"rgb":"var(--TC9)"},"icon":{"selectedKey":1,"visible":false},"title":{"rType":"text","val":"Establish institutional responsibilities"},"extendedDesc":{"visible":true,"text":{"rType":"text","val":"Institutional bodies are identified and empowered to develop and implement proactive preparedness plans. These plans mitigate drought impacts and ensure adequate and timely responses during droughts."}}},"TpgrD_1eg":{"type":"element","id":"TpgrD_1eg","color":{"opac":1,"rgb":"var(--TC10)"},"icon":{"selectedKey":1,"visible":false},"title":{"rType":"text","val":"Promote gender equality and social inclusion"},"extendedDesc":{"visible":true,"text":{"rType":"text","val":"The plan is used to address the underlying causes of gender inequality and social exclusion contributing to drought vulnerability. It also tackles disaster-related trauma influencing behaviors during the time between droughts."}}},"NzCf5M5NN":{"type":"element","id":"NzCf5M5NN","color":{"opac":1,"rgb":"var(--TC7)"},"icon":{"selectedKey":1,"visible":false},"title":{"rType"