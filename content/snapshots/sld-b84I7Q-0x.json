val":"Scene 2"},"bg":{"selectedKey":"fill","fill":{"opac":1,"rgb":"var(--TC8)"}},"style":{"selectedKey":"textOverlapping"},"txtBg":{"fill":{"opac":0,"rgb":"#000"}},"e":{"i":{"bPALTzj00":{"type":"element","id":"bPALTzj00","link":{"selectedKey":"image","val":"ZNScTRAj0"},"animation":{"selectedKey":"fade"},"pos":{"x":910,"y":50},"icon":{"selectedKey":18},"size":{"selectedKey":"m"},"iconColor":{"opac":1,"rgb":"var(--TC14)"}}},"p":["bPALTzj00"]},"desc":{"rType":"richtext","val":{"ops":[{"insert":"The connection among the three pillars of drought management  demonstrates the need for an iterative process to generate gender information in support of the three pillars.","attributes":{"color":"var(--TC14)"}},{"insert":"\n\n","attributes":{"size":"normal"}},{"insert":"There are 4 key actions to integrate gender equality and inclusion within step 5 of the 10 steps structure to integrate GESI in drought planning, namely “Prepare the main tenets of national drought management plan along the drought management pillars”. ","attributes":{"color":"var(--TC14)"}},{"insert":"\n","attributes":{"size":"normal"}}]},"hali":""}}},"p":["ZNScTRAj0","IDJKl_zUR"]}}},"BriFi7yRSP":{"id":"BriFi7yRSP","type":"interactive","subtype":"interactiveInfographics","setup":{"type":{"selectedKey":2},"title":{"rType":"text","tag":"p"},"cover":{"selectedKey":"fill","fill":{"opac":1,"rgb":"var(--TC14)"}},"elem":{"i":{"8xPnBMOHl":{"type":"element","id":"8xPnBMOHl","color":{"opac":1,"rgb":"#bd8e71"},"icon":{"selectedKey":1,"visible":false},"title":{"rType":"text","val":"Action area 1"},"extendedDesc":{"visible":true,"text":{"rType":"text","val":"Institutional leadership and commitment - make gender equality and inclusion a core business goal. \n\nInstitutions responsible for drought management must ensure that they have the right processes, systems, leadership and resources for engendering the drought policies and plan."}},"desc":{"rType":"text","val":""}},"XHZzY-RlR":{"type":"element","id":"XHZzY-RlR","color":{"opac":1,"rgb":"var(--TC2)"},"icon":{"selectedKey":1,"visible":false},"title":{"rType":"text","val":"Action area 2"},"extendedDesc":{"visible":true,"text":{"rType":"text","val":"Gender inclusion analysis that drives change. \n\nGender responsive impact assessments is a tool  to understand the structural gender inequalities on which gender gaps are based. The current gender and equality context, and projected impacts should be considered. "}}},"sPYl1Y3hm":{"type":"element","id":"sPYl1Y3hm","color":{"opac":1,"rgb":"var(--TC9)"},"icon":{"selectedKey":1,"visible":false},"title":{"rType":"text","val":"Action area 3"},"extendedDesc":{"visible":true,"text":{"rType":"text","val":"Meaningful and inclusive participation,  decision making and partnerships . \n\n﻿Adopt a “nothing about them without them” approach. It includes training, financial support, long term engagement, and working in partnership with organizations such as women’s, indigenous peoples’ and persons with disabilities. "}}},"TpgrD_1eg":{"type":"element","id":"TpgrD_1eg","color":{"opac":1,"rgb":"var(--TC10)"},"icon":{"selectedKey":1,"visible":false},"title":{"rType":"text","val":"Action area 4"},"extendedDesc":{"visible":true,"text":{"rType":"text","val":"Equal access to and control of resources.\n\nCreating equal access to resources requires addressing legal barriers, customary laws, and cultural practices. Gender-transformative approaches should engage communities in drought-prone areas to help overcome these obstacles."}}}},"p":["8xPnBMOHl","XHZzY-RlR","sPYl1Y3hm","TpgrD_1eg"]}}}},"v":"1"}