,"setup":{"background":{"selectedKey":"image","fill":{"opac":1,"rgb":"#FFF"},"img":{"filt":{"opac":100,"gray":0,"blur":0,"tint":{"rgb":"#FFF","opac":0}},"pos":{"type":"fit","fit":{"bg":{"color":{"rgb":"#FFF","opac":100},"gradient":{"angle":0,"opac":0.5,"stops":[{"color":"#000000","pos":0},{"color":"#000000","pos":100}]}},"vali":"center","hali":"center","margin":0},"crop":{"bg":{"color":{"rgb":"#FFF","opac":0},"gradient":{"angle":0,"opac":0.5,"stops":[{"color":"#000000","pos":0},{"color":"#000000","pos":100}]}},"poi":{"x":256.5,"y":175.5}},"mask":{"shape":1,"bg":{"color":{"rgb":"#FFF","opac":0},"gradient":{"angle":0,"opac":0.5,"stops":[{"color":"#000000","pos":0},{"color":"#000000","pos":100}]}}}},"measures":{"size":{"width":621,"height":352}},"orig":{"rType":"asset","rSubType":"image","fileName":"tool.jpg","fileSize":46301,"val":"mc-2ba431a0cb451f0358796c4e124ac546.jpg","aid":"v-mVpGfboP5"}}},"title":{"rType":"text","tag":"p","val":""},"points":{"i":{"5-N2wAyBk":{"type":"point","id":"5-N2wAyBk","spotPosition":{"x":606,"y":812},"icon":{"selectedKey":9},"size":{"selectedKey":"m"},"iconColor":{"opac":1,"rgb":"var(--TC6)"},"text":{"rType":"text","val":"DM ignores different gender roles, responsibilities, needs and priorities for men, women. \nIt perpetuates vulnerabilities and increases potential of drought disasters"}},"QUjNQmSB9":{"type":"point","id":"QUjNQmSB9","spotPosition":{"x":645,"y":653},"icon":{"selectedKey":9},"size":{"selectedKey":"m"},"iconColor":{"opac":1,"rgb":"var(--TC6)"},"text":{"rType":"text","val":"DM fails to address differing needs, provisions are vague. It unintentionally reinforces inequalities."}},"Jm4hlmGdG":{"type":"point","id":"Jm4hlmGdG","spotPosition":{"x":681,"y":518},"icon":{"selectedKey":11},"size":{"selectedKey":"m"},"iconColor":{"opac":1,"rgb":"#ebf46e"},"text":{"rType":"text","val":"DM recognizes inequalities and differing needs, but treats symptoms instead of the root causes. Plans  do little to change the larger contextual issues that influence gender relations and perpetuate inequalities."}},"Xdr8vAtW0":{"type":"point","id":"Xdr8vAtW0","spotPosition":{"x":727,"y":372},"icon":{"selectedKey":11},"size":{"selectedKey":"m"},"iconColor":{"opac":1,"rgb":"#ebf46e"},"text":{"rType":"text","val":"DM addresses GESI implications of any planned action and at each stage, from design, through implementation, monitoring to evaluation, and adjustment. DM ensures that women and men, and marginalized groups have equal access to and control over resources and actively participate in decision-making processes."}},"qSseR8FyL":{"type":"point","id":"qSseR8FyL","spotPosition":{"x":830,"y":201},"icon":{"selectedKey":14},"size":{"selectedKey":"m"},"iconColor":{"opac":1,"rgb":"var(--TC5)"},"text":{"rType":"text","val":"DM addresses root causes of gender inequalities by removing structural barriers, reshaping unequal power relations, and changing negative or harmful norms and practices. \nDM recognizes and strengthens positive norms that promote more equitable DM outcomes. Preparedness and response plans consider gender-differentiated vulnerabilities and capacities. They challenge power imbalances and transform gender roles."}}},"p":["5-N2wAyBk","QUjNQmSB9","Jm4hlmGdG","Xdr8vAtW0","qSseR8FyL"]}}}},"v":"1"}